# Copy this file to `.env.local` and fill in your database connection string.
#
# Get it from: supabase.com/dashboard -> your project -> Connect (top bar)
# -> "Transaction pooler" -> copy the string and replace [YOUR-PASSWORD]
# with your database password (URL-encode special characters: @ -> %40,
# # -> %23, $ -> %24, % -> %25).
#
# Without this, the site runs in "demo mode" (baskets are stored in memory
# and disappear on restart) - fine for local preview, NOT for real use.

DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
