# Copy this file to `.env.local` and fill in your Supabase project values.
# Get them from: https://supabase.com/dashboard -> your project -> Settings -> API
#
# Without these, the site still runs in "demo mode" (baskets are stored in
# memory and disappear on restart) - fine for local preview, NOT for real use.

SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
